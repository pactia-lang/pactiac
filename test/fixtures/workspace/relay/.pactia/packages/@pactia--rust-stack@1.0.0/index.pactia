pactia 1.0
// Package: @pactia/rust-stack — Rust / Actix / Node backend stack (ANB)

export def #rust-stack in product {
  > Rust / Actix / Node backend stack (ANB) — primary APIs in Rust on actix-web and tokio.
  > Node is a sidecar only (admin tooling, asset bundling); never the request-serving hot path.
  > All handlers return errors via the platform envelope — no ad hoc JSON error bodies.
  > List endpoints use cursor pagination; override page size only with paginated and list service macros.
  > Persistence via sqlx with PostgreSQL; cache via redis; async integration via kafka when declared.
  > CI defaults to GitHub Actions; images are OCI multi-stage cargo release plus distroless runtime.
  > Deploy targets Kubernetes or Docker Compose; health checks expose health and ready routes.
  > Allowed Rust crates are the default dependency set for generated services; denied crates fail codegen audit.

  @stack {
    language: rust,
    edition: "2021",
    framework: actix-web,
    runtime: tokio,
    nodeRole: sidecar,
    package: "@pactia/rust-stack",
    errorEnvelope: platform,
    pagination: cursor,
    orm: sqlx,
    database: postgresql,
    cache: redis,
    messaging: kafka,
    ci: github-actions,
    container: docker,
    deploy: kubernetes,
    allowedCrates: [
      "tokio",
      "actix-web",
      "actix-rt",
      "actix-http",
      "sqlx",
      "serde",
      "serde_json",
      "tracing",
      "tracing-subscriber",
      "uuid",
      "chrono",
      "thiserror",
      "anyhow",
      "rdkafka",
      "redis",
      "jsonwebtoken",
      "validator",
      "config",
      "dotenvy"
    ],
    deniedCrates: [
      "rocket",
      "diesel",
      "openssl",
      "native-tls",
      "hyper",
      "axum",
      "warp",
      "reqwest",
      "tonic",
      "prost",
      "async-std",
      "smol"
    ],
  }
}

export def #paginated in service {
  modifiers.pageSize: 50,
  modifiers.paginated: true,
}

export def #list in service {
  #paginated
}

export def #detail in service {
  modifiers.paginated: false,
}
