{
  "service": {
    "name": "OrderService",
    "description": "Core order relay API",
    "flags": {
      "database": true,
      "cache": false,
      "events": false
    },
    "endpoints": [
      {
        "id": "list_orders",
        "method": "GET",
        "path": "/api/v1/orders",
        "summary": "Operator browses orders in a paginated table",
        "authorization": {
          "type": "ROLE",
          "roles": [
            "Operator"
          ]
        },
        "response": {
          "bodyRef": "OrderListResponse"
        },
        "errors": [],
        "modifiers": {
          "pageSize": 50,
          "paginated": true
        },
        "emits": [],
        "provenance": "Pactia"
      },
      {
        "id": "create_order",
        "method": "POST",
        "path": "/api/v1/orders",
        "request": {
          "bodyRef": "CreateOrderRequest",
          "provenance": "INFERRED"
        },
        "response": {
          "bodyRef": "CreateOrderResponse"
        },
        "errors": [],
        "modifiers": {
          "create": true,
          "idempotency": "REQUIRED"
        },
        "emits": [],
        "provenance": "Pactia"
      }
    ],
    "scenarios": [
      {
        "name": "Operator creates an order",
        "service": "OrderService",
        "provenance": "Pactia",
        "given": {
          "actor": "Operator",
          "auth": "logged_in"
        },
        "when": {
          "method": "POST",
          "path": "/api/v1/orders",
          "body": {
            "valid": true
          }
        },
        "then": {
          "httpStatus": "201",
          "kafkaEmits": "order.created"
        }
      },
      {
        "name": "Operator lists orders",
        "service": "OrderService",
        "provenance": "Pactia",
        "given": {
          "actor": "Operator",
          "auth": "logged_in"
        },
        "when": {
          "method": "GET",
          "path": "/api/v1/orders"
        },
        "then": {
          "httpStatus": "200",
          "bodyRef": "OrderListResponse"
        }
      },
      {
        "name": "Unauthorized create rejected",
        "service": "OrderService",
        "provenance": "Pactia",
        "given": {
          "actor": "Anonymous"
        },
        "when": {
          "method": "POST",
          "path": "/api/v1/orders"
        },
        "then": {
          "httpStatus": "403"
        }
      }
    ],
    "obligations": []
  }
}
