{
  "service": {
    "name": "OrderService",
    "description": "Core order relay API",
    "flags": {
      "database": true
    },
    "extensions": [
      {
        "roles": [
          "Operator"
        ],
        "provenance": "Pactia"
      },
      {
        "modifiers": {
          "pageSize": 50,
          "paginated": true,
          "bodyRef": "OrderListResponse"
        },
        "id": "list_orders",
        "method": "GET",
        "path": "/api/v1/orders",
        "extensions": [
          {
            "id": "order_list",
            "platform": "web",
            "screen": "{ id : order_list }",
            "route": "{ path : /orders }",
            "text": "Operator browses orders in a paginated table",
            "provenance": "Pactia"
          }
        ],
        "provenance": "Pactia"
      },
      {
        "modifiers": {
          "create": true,
          "idempotency": "REQUIRED",
          "bodyRef": "CreateOrderResponse"
        },
        "id": "create_order",
        "method": "POST",
        "path": "/api/v1/orders",
        "provenance": "Pactia"
      },
      {
        "id": "operator_creates_order",
        "name": "Operator creates an order",
        "when": "Operator is logged in and POST /api/v1/orders with valid body",
        "then": "status is 201 and order.created is emitted",
        "provenance": "Pactia"
      },
      {
        "id": "operator_lists_orders",
        "name": "Operator lists orders",
        "when": "Operator is logged in and GET /api/v1/orders",
        "then": "status is 200 and response matches OrderListResponse",
        "provenance": "Pactia"
      },
      {
        "id": "unauthorized_create",
        "name": "Unauthorized create rejected",
        "when": "Anonymous POST /api/v1/orders",
        "then": "status is 403",
        "provenance": "Pactia"
      }
    ]
  }
}
