  "product": {
    "product": {
      "name": "Relay",
      "body": [
        {
          "kind": "prose",
          "text": "B2B order relay between suppliers and retailers",
          "provenance": "GUIDANCE"
        },
        {
          "kind": "prose",
          "text": "Rust / Actix / Node backend stack ( ANB ) — primary APIs in Rust on actix-web and tokio.",
          "provenance": "GUIDANCE"
        },
        {
          "kind": "prose",
          "text": "Node is a sidecar only ( admin tooling , asset bundling ) ; never the request-serving hot path.",
          "provenance": "GUIDANCE"
        },
        {
          "kind": "prose",
          "text": "All handlers return errors via the platform envelope — no ad hoc JSON error bodies.",
          "provenance": "GUIDANCE"
        },
        {
          "kind": "prose",
          "text": "List endpoints use cursor pagination ; override page size only with paginated and list service macros.",
          "provenance": "GUIDANCE"
        },
        {
          "kind": "prose",
          "text": "Persistence via sqlx with PostgreSQL ; cache via redis ; async integration via kafka when declared.",
          "provenance": "GUIDANCE"
        },
        {
          "kind": "prose",
          "text": "CI defaults to GitHub Actions ; images are OCI multi-stage cargo release plus distroless runtime.",
          "provenance": "GUIDANCE"
        },
        {
          "kind": "prose",
          "text": "Deploy targets Kubernetes or Docker Compose ; health checks expose health and ready routes.",
          "provenance": "GUIDANCE"
        },
        {
          "kind": "prose",
          "text": "Allowed Rust crates are the default dependency set for generated services ; denied crates fail codegen audit.",
          "provenance": "GUIDANCE"
        },
        {
          "tag": "stack",
          "language": "rust",
          "edition": 2021,
          "framework": "actix-web",
          "runtime": "tokio",
          "nodeRole": "sidecar",
          "package": "@pactia/rust-stack",
          "errorEnvelope": "platform",
          "pagination": "cursor",
          "orm": "sqlx",
          "database": "postgresql",
          "cache": "redis",
          "messaging": "kafka",
          "ci": "github-actions",
          "container": "docker",
          "deploy": "kubernetes",
          "allowedCrates": [
            "tokio",
            "actix-web",
            "actix-rt",
            "actix-http",
            "sqlx",
            "serde",
            "serde_json",
            "tracing",
            "tracing-subscriber",
            "uuid",
            "chrono",
            "thiserror",
            "anyhow",
            "rdkafka",
            "redis",
            "jsonwebtoken",
            "validator",
            "config",
            "dotenvy"
          ],
          "deniedCrates": [
            "rocket",
            "diesel",
            "openssl",
            "native-tls",
            "hyper",
            "axum",
            "warp",
            "reqwest",
            "tonic",
            "prost",
            "async-std",
            "smol"
          ],
          "provenance": "Pactia"
        },
        {
          "tag": "topology",
          "mode": "microservices",
          "provenance": "Pactia"
        },
        {
          "tag": "tenancy",
          "mode": "single",
          "provenance": "Pactia"
        },
        {
          "tag": "guide",
          "text": "Handlers return errors via the platform envelope only",
          "provenance": "GUIDANCE"
        },
        {
          "tag": "guide",
          "text": "List endpoints use cursor pagination — not offset",
          "provenance": "GUIDANCE"
        }
      ]
    }
  },
