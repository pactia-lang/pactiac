{
  "product": {
    "name": "Relay",
    "description": "B2B order relay between suppliers and retailers",
    "stackId": "@pactia/rust-anb",
    "topology": {
      "mode": "MICROSERVICES"
    },
    "tenancy": {
      "mode": "SINGLE_TENANT"
    },
    "guide": [
      "Handlers return errors via the platform envelope only",
      "List endpoints use cursor pagination — not offset"
    ],
    "surfaces": [
      {
        "id": "order_list",
        "platform": "web",
        "screen": {
          "id": "order_list",
          "route": {
            "path": "/orders"
          }
        },
        "bind": {
          "service": "OrderService",
          "endpoint": "list_orders"
        },
        "description": "Operator browses orders in a paginated table"
      }
    ],
    "security": {
      "statements": [
        {
          "id": "orders",
          "module": "orders",
          "text": "All order mutations must be audit-logged"
        }
      ]
    },
    "deployment": {
      "id": "orders",
      "environments": [
        {
          "id": "staging",
          "replicas": 2,
          "region": "eu-west-1"
        },
        {
          "id": "production",
          "replicas": 3,
          "region": "eu-west-1"
        }
      ],
      "gates": [
        {
          "id": "production",
          "scenarios": "pass",
          "coverage": ">= 80%"
        }
      ]
    }
  }
}
