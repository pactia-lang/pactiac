{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pactia.io/schemas/tags/deploy-v1.json",
  "title": "Pactia kernel tag @deploy (v1)",
  "description": "Product deployment overrides: environments and promotion gates.",
  "type": "object",
  "required": ["environments"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "environments": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/environment" }
    },
    "gates": {
      "type": "array",
      "items": { "$ref": "#/$defs/gate" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "environment": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "replicas": { "type": "integer", "minimum": 1 },
        "region": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "gate": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "scenarios": { "type": "string", "minLength": 1 },
        "coverage": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  }
}
