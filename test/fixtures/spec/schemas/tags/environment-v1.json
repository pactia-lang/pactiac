{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pactia.io/schemas/tags/environment-v1.json",
  "title": "Pactia kernel tag @environment (v1)",
  "description": "Deployment environment override nested under @deploy.",
