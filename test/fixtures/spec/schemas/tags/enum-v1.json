{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pactia.io/schemas/tags/enum-v1.json",
  "title": "Pactia kernel tag @enum (v1)",
  "description": "Model enum with named values.",
  "type": "object",
  "required": ["name", "values"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "values": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": false
}
