{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pactia.io/schemas/tags/emit-v1.json",
  "title": "Pactia kernel tag @emit (v1)",
  "description": "Domain event emitted by an @api endpoint.",
  "type": "object",
  "required": ["event"],
  "properties": {
    "event": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[\\w.]+$"
    }
  },
  "additionalProperties": false
}
