{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pactia.io/schemas/tags/policy-v1.json",
  "title": "Pactia kernel tag @policy (v1)",
  "description": "Retention, residency, and compliance policy facts.",
  "type": "object",
  "required": ["id"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "retain": {
      "type": "object",
      "required": ["entity", "period"],
      "properties": {
        "entity": { "type": "string", "minLength": 1 },
        "period": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "residency": { "type": "string", "minLength": 1 }
  },
  "anyOf": [{ "required": ["retain"] }, { "required": ["residency"] }],
  "additionalProperties": false
}
