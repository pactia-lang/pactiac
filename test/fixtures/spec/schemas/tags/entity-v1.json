{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pactia.io/schemas/tags/entity-v1.json",
  "title": "Pactia kernel tag @entity (v1)",
  "description": "Model entity declaration with at least one field.",
  "type": "object",
  "required": ["name", "fields"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "fields": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "minLength": 1 },
          "array": { "type": "boolean" },
          "optional": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
