{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pactia.io/schemas/tags/compliance-v1.json",
  "title": "Pactia kernel tag @compliance (v1)",
  "description": "Regulatory or vertical compliance pack declaration.",
  "type": "object",
  "required": ["id"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "framework": { "type": "string", "minLength": 1 },
    "applies_to": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "object" }
    }
  },
  "anyOf": [
    { "required": ["framework"] },
    { "required": ["applies_to"] },
    { "required": ["rules"] }
  ],
  "additionalProperties": true
}
