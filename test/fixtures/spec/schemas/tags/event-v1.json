{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pactia.io/schemas/tags/event-v1.json",
  "title": "Pactia kernel tag @event (v1)",
  "description": "Domain event declaration with payload and handler wiring.",
  "type": "object",
  "required": ["id"],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[\\w.]+$"
    },
    "payload": { "type": "string", "minLength": 1 },
    "handler": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 }
  },
  "anyOf": [{ "required": ["payload"] }, { "required": ["handler"] }, { "required": ["description"] }],
  "additionalProperties": false
}
