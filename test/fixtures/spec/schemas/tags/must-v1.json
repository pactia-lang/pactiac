{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pactia.io/schemas/tags/must-v1.json",
  "title": "Pactia kernel tag @must (v1)",
  "description": "Service obligation with trigger and outcome prose.",
  "type": "object",
  "required": ["id"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "on": { "type": "string", "minLength": 1 },
    "lines": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "text": { "type": "string", "minLength": 1 }
  },
  "anyOf": [{ "required": ["on", "lines"] }, { "required": ["text"] }],
  "additionalProperties": false
}
