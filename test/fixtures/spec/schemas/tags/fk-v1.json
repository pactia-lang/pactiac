{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pactia.io/schemas/tags/fk-v1.json",
  "title": "Pactia kernel tag @fk (v1)",
  "description": "Foreign key field modifier referencing another entity.",
  "type": "object",
  "required": ["entity", "field", "references"],
  "properties": {
    "entity": { "type": "string", "minLength": 1 },
    "field": { "type": "string", "minLength": 1 },
    "references": {
      "type": "object",
      "required": ["entity"],
      "properties": {
        "entity": { "type": "string", "minLength": 1 },
        "field": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
