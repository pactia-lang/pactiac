{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pactia.io/schemas/tags/config-v1.json",
  "title": "Pactia kernel tag @config (v1)",
  "description": "Module configuration profile with named entries.",
  "type": "object",
  "required": ["profile", "entries"],
  "properties": {
    "profile": { "type": "string", "minLength": 1 },
    "entries": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "properties": {
          "required": { "type": "boolean" },
          "secret": { "type": "boolean" },
          "default": { "type": "string" },
          "description": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
