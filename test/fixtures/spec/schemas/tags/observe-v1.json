{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pactia.io/schemas/tags/observe-v1.json",
  "title": "Pactia kernel tag @observe (v1)",
  "description": "Service-level objectives for module observability.",
  "type": "object",
  "required": ["slos"],
  "properties": {
    "slos": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["service", "metric", "target"],
        "properties": {
          "service": { "type": "string", "minLength": 1 },
          "metric": { "type": "string", "minLength": 1 },
          "target": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
