{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pactia.io/schemas/tags/states-v1.json",
  "title": "Pactia kernel tag @states (v1)",
  "description": "Entity field state machine with transitions.",
  "type": "object",
  "required": ["id", "entity", "transitions"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "entity": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[\\w.]+$"
    },
    "transitions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["from", "to"],
        "properties": {
          "from": { "type": "string", "minLength": 1 },
          "to": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
