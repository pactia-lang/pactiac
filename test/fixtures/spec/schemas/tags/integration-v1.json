{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pactia.io/schemas/tags/integration-v1.json",
  "title": "Pactia kernel tag @integration (v1)",
  "description": "Inbound or outbound integration boundary.",
  "type": "object",
  "required": ["name", "direction"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "direction": { "type": "string", "enum": ["INBOUND", "OUTBOUND"] },
    "auth": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["API_KEY", "HMAC", "BEARER", "OAUTH2", "NONE"]
        },
        "env": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "mapsTo": { "type": "string", "minLength": 1 },
    "purpose": { "type": "string", "minLength": 1 }
  },
  "allOf": [
    {
      "if": { "properties": { "direction": { "const": "INBOUND" } }, "required": ["direction"] },
      "then": { "required": ["mapsTo"] }
    }
  ],
  "additionalProperties": false
}
