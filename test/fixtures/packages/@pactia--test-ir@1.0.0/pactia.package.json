{
  "name": "@pactia/test-ir",
  "version": "1.0.0",
  "kind": "library",
  "registry": {
    "tags": [
      {
        "name": "api",
        "in": ["service"],
        "ir": {
          "file": "service",
          "path": "endpoints[]",
          "merge": "append_host"
        }
      },
      {
        "name": "output",
        "in": ["service"],
        "ir": {
          "file": "service",
          "path": "response",
          "merge": "merge_into_host"
        }
      }
    ]
  }
}
