{
  "name": "@pactia/pactiac",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "pactiac": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "build:bin:linux-x64": "bun build ./src/cli.ts --compile --minify --target=bun-linux-x64 --outfile dist/pactiac-linux-x64",
    "build:bin:linux-arm64": "bun build ./src/cli.ts --compile --minify --target=bun-linux-arm64 --outfile dist/pactiac-linux-arm64",
    "build:bin:darwin-arm64": "bun build ./src/cli.ts --compile --minify --target=bun-darwin-arm64 --outfile dist/pactiac-darwin-arm64",
    "build:bin:darwin-x64": "bun build ./src/cli.ts --compile --minify --target=bun-darwin-x64 --outfile dist/pactiac-darwin-x64",
    "build:bin:windows-x64": "bun build ./src/cli.ts --compile --minify --target=bun-windows-x64 --outfile dist/pactiac-windows-x64.exe",
    "build:bin": "npm run build:bin:linux-x64 && npm run build:bin:linux-arm64 && npm run build:bin:darwin-arm64 && npm run build:bin:darwin-x64 && npm run build:bin:windows-x64",
    "test:bin": "npm run build:bin:linux-x64 && bash scripts/smoke-binary.sh",
    "test": "npm run build && node --import tsx --test $(find src -name '*.test.ts')",
    "test:coverage": "npm run build && c8 --reporter=lcov --reporter=text node --import tsx --test $(find src -name '*.test.ts')",
    "compile": "node dist/cli.js compile",
    "generate:golden": "npm run build && node --import tsx scripts/generate-golden.ts",
    "hooks:install": "bash scripts/install-hooks.sh"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "c8": "^11.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pactia-lang/pactiac.git"
  }
}
